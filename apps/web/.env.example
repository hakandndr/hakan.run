# Supabase — copy this file to .env and fill in your project values.
# Found in: Supabase Dashboard → Project Settings → API
#
# Both of these are PUBLIC values (the anon key is safe in the browser bundle;
# security is enforced by Row Level Security on the database).

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─────────────────────────────────────────────────────────────────────────────
# NOTE: the service_role key is NOT stored here (or anywhere in this repo).
# It is admin-level and bypasses Row Level Security. The one-time seed script
# reads it from an environment variable instead — see supabase/seed.mjs header.
# ─────────────────────────────────────────────────────────────────────────────
